# Open Door — secrets & config. Copy this file to ".env" and fill in real values:
#   cp .env.example .env
# The server loads .env automatically on startup. Never commit the real .env.

# --- Live planner (Anthropic centerpiece) ---
ANTHROPIC_API_KEY=

# --- Browse leg ---
# Local Playwright Chromium needs NO key. Set these only to use the Browserbase
# cloud browser instead. OPENDOOR_BROWSE=real turns the live browse leg on.
OPENDOOR_BROWSE=real
# OPENDOOR_HEADED=1            # show the Chromium window during a run
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- Speak leg (Deepgram) ---
# OPENDOOR_SPEAK=real         # use real Deepgram voice (TTS+STT); else browser Web Speech
DEEPGRAM_API_KEY=

# --- Observability (Sentry) — optional ---
# OPENDOOR_SENTRY=1           # uncomment to enable; requires SENTRY_DSN below
SENTRY_DSN=

# --- Planner cost lever ---
# Default is claude-opus-4-8. Use a cheaper model to iterate offline and save budget:
# OPENDOOR_PLANNER_MODEL=claude-haiku-4-5
